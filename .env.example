# OpenRouter (used by notebooks/04_patent_review.ipynb)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=anthropic/claude-opus-4.7
# Pass 0 only (large context digest in 04_patent_review.ipynb)
OPENROUTER_MODEL_PASS0=google/gemini-pro-latest
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDING_MODEL=baai/bge-m3
# Phase 4 Pass 2 semantic splitting
# PHASE4_TAU_B=0.35
# PHASE4_MIN_SENTENCES=3
# PHASE4_TARGET_CHUNK_TOKENS=384
# PHASE4_MAX_CHUNK_TOKENS=768
# PHASE4_MIN_CHUNK_TOKENS=64
# PHASE4_OVERLAP_TOKENS=64
# Phase 5 Gemini dual-domain tagging
# PHASE5_TAU_CLINICAL=0.7
# PHASE5_TAU_LEGAL=0.6
# PHASE5_TAU_UNCERTAIN_LOW=0.4
# PHASE5_CONCURRENCY=10
# PHASE5_SKIP_TINY_HEADERS=false
# PHASE5_RETRY_FAILED=true
# PHASE5_RETRY_CONCURRENCY=2
# PHASE5_LOG_EVERY=20
# PHASE5_LOG_LEVEL=INFO
# Phase 5.1 legal-only augmentation
# PHASE5_1_CONCURRENCY=8
# PHASE5_1_ENABLE_RULES=true
# PHASE5_1_ALL_PROSE=false
# PHASE5_1_RETRY_FAILED=true
# PHASE5_1_RETRY_CONCURRENCY=2
# PHASE5_1_LOG_EVERY=15

# Optional OpenRouter attribution headers
# OPENROUTER_HTTP_REFERER=https://localhost
# OPENROUTER_APP_TITLE=medrecs-patent-review

MAX_EXTRACTION_RETRIES=3

