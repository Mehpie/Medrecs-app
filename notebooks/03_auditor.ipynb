{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# 03 — Auditor (CRAG-lite)\n",
        "\n",
        "Deterministic citation checks + Gemini auditor. Saves `final_report.md` when audit passes."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import json\n",
        "import sys\n",
        "from pathlib import Path\n",
        "\n",
        "_root = Path.cwd().resolve()\n",
        "if _root.name == \"notebooks\":\n",
        "    _root = _root.parent\n",
        "if str(_root) not in sys.path:\n",
        "    sys.path.insert(0, str(_root))\n",
        "\n",
        "from src.nb_utils import setup_project_root\n",
        "from src.auditor_checks import deterministic_audit, extract_cited_pages\n",
        "from src.gemini_json import generate_json\n",
        "from src.load_pages import DEFAULT_OUTPUT_DIR\n",
        "from src.prompts import AUDITOR_SYSTEM\n",
        "from src.schemas import AuditorVerdict\n",
        "\n",
        "ROOT = setup_project_root()\n",
        "\n",
        "draft_path = DEFAULT_OUTPUT_DIR / \"part1_draft.md\"\n",
        "if not draft_path.exists():\n",
        "    raise FileNotFoundError(\"Run 02_synthesis first.\")\n",
        "\n",
        "draft = draft_path.read_text(encoding=\"utf-8\")\n",
        "\n",
        "extractions = {}\n",
        "for name in (\"ortho\", \"neuro\", \"billing\", \"baseline\"):\n",
        "    extractions[name] = json.loads(\n",
        "        (DEFAULT_OUTPUT_DIR / f\"{name}.json\").read_text(encoding=\"utf-8\")\n",
        "    )\n",
        "\n",
        "print(\"Cited pages:\", extract_cited_pages(draft))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "det_failures = deterministic_audit(draft, extractions)\n",
        "if det_failures:\n",
        "    print(\"Deterministic audit FAILED:\")\n",
        "    for f in det_failures:\n",
        "        print(f\"  - {f}\")\n",
        "else:\n",
        "    print(\"Deterministic audit passed.\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "auditor_prompt = (\n",
        "    \"Draft Part I markdown:\\n\"\n",
        f\"{draft}\\n\\n\"\n",
        "    \"Structured extractions JSON:\\n\"\n",
        f\"{json.dumps(extractions, indent=2)}\"\n",
        ")\n",
        "\n",
        "verdict, usage = generate_json(AUDITOR_SYSTEM, auditor_prompt, AuditorVerdict)\n",
        "print(\"Token usage:\", usage)\n",
        "print(f\"pass: {verdict.pass_}\")\n",
        "for f in verdict.failures:\n",
        "    print(f\"  FAILURE: {f}\")\n",
        "for fix in verdict.suggested_fixes:\n",
        "    print(f\"  FIX: {fix}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "if verdict.pass_ and not det_failures:\n",
        "    final_path = DEFAULT_OUTPUT_DIR / \"final_report.md\"\n",
        "    final_path.write_text(draft, encoding=\"utf-8\")\n",
        "    print(f\"Saved {final_path}\")\n",
        "else:\n",
        "    print(\"Report not finalized. Re-run 02_synthesis with suggested_fixes in the prompt.\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Bad-draft test (auditor should fail)\n",
        "\n",
        "Proves the loop catches unsupported claims."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "bad_draft = (\n",
        "    \"Patient achieved 999 degrees shoulder flexion immediately post-MVA \"\n",
        "    \"[src. Pg. 999].\"\n",
        ")\n",
        "bad_det = deterministic_audit(bad_draft, extractions)\n",
        "print(\"Bad draft deterministic failures (expected):\", bad_det)\n",
        "\n",
        "bad_verdict, _ = generate_json(\n",
        "    AUDITOR_SYSTEM,\n",
        "    f\"Draft:\\n{bad_draft}\\n\\nExtractions:\\n{json.dumps(extractions)}\",\n",
        "    AuditorVerdict,\n",
        ")\n",
        "print(f\"Bad draft LLM pass (expected False): {bad_verdict.pass_}\")\n",
        "print(\"Failures:\", bad_verdict.failures)"
      ]
    }
  ],
